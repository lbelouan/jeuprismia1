  },
  "devDependencies": {
    "@babel/core": "^7.0.0-beta.42",
    "@babel/preset-env": "^7.0.0-beta.42",
    "babel-loader": "^8.0.0-beta",
    "express": "^4.16.3",
    "webpack": "^4.0.1",
    "webpack-cli": "^3.1.1"
  },
  "dependencies": {
    "cooljs": "^1.0.2"
  }
}
